{% doc %}
  Renders a progress bar toward the free shipping threshold set in theme settings.
  Reads cart.total_price, so it re-renders with fresh values whenever the cart
  drawer re-renders via the Section Rendering API - no extra JS needed.
{% enddoc %}

{%- if settings.free_shipping_threshold and settings.free_shipping_threshold > 0 -%}
  {%- liquid
    assign threshold_cents = settings.free_shipping_threshold | times: 100
    assign remaining_cents = threshold_cents | minus: cart.total_price
    assign remaining_formatted = remaining_cents | money
    assign progress = cart.total_price | times: 100.0 | divided_by: threshold_cents
    if progress > 100
      assign progress = 100
    endif
  -%}
  <div class="free-shipping-bar">
    <p class="free-shipping-bar__message">
      {%- if remaining_cents <= 0 -%}
        {{ 'content.free_shipping_unlocked' | t }}
      {%- else -%}
        {{ 'content.free_shipping_remaining' | t: amount: remaining_formatted }}
      {%- endif -%}
    </p>
    <div
      class="free-shipping-bar__track"
      role="progressbar"
      aria-valuenow="{{ progress }}"
      aria-valuemin="0"
      aria-valuemax="100"
    >
      <div
        class="free-shipping-bar__fill"
        style="width: {{ progress }}%;"
      ></div>
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .free-shipping-bar {
    padding-inline: var(--cart-drawer-padding);
    padding-block-end: var(--padding-lg);
  }

  .free-shipping-bar__message {
    margin: 0 0 var(--margin-3xs);
    font-size: var(--font-size--sm);
  }

  .free-shipping-bar__track {
    height: 4px;
    border-radius: 100px;
    background-color: rgb(var(--color-foreground-rgb) / var(--opacity-10-25));
    overflow: hidden;
  }

  .free-shipping-bar__fill {
    height: 100%;
    background-color: rgb(var(--color-foreground-rgb));
    border-radius: 100px;
    transition: width 0.3s ease;
  }
{% endstylesheet %}
